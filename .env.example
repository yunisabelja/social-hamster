# SocialScope — Environment Variables
# Copy this file to .env and fill in your keys

# YouTube Data API v3 key
# Get one free at: https://console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# TikTok msToken cookie (optional but improves results + region targeting)
# Get it: Log into TikTok in Chrome → F12 → Application → Cookies → msToken
TIKTOK_MS_TOKEN=your_mstoken_here

# If left blank, the app runs with realistic mock data so you can test the UI
